# ── AI Providers ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here

# GitHub — optional but strongly recommended (avoids 60 req/hr rate limit)
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Model Routing ─────────────────────────────────────────────────────────────
# Pro model: used for planning and synthesis (higher quality, slower)
PLANNER_MODEL=gemini-1.5-pro
# Flash model: used for search analysis, verification, entity extraction (fast, parallel)
RESEARCHER_MODEL=gemini-1.5-flash

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/researchos

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_64_char_string

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
